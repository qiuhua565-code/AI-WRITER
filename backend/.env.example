APP_NAME=AI-StoryFlow
DEBUG=true
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── 数据库（本地开发：本机 Postgres）────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aistoryflow

# 若要从「你的电脑」连「服务器上的 Postgres」做迁移/调试，把上面一行改成（示例，请替换 IP/密码/库名）：
# DATABASE_URL=postgresql+asyncpg://postgres:你的密码@服务器公网IP:5432/aistoryflow
# 前提：服务器 Postgres 已监听 0.0.0.0:5432 且安全组/防火墙放行；生产建议勿对公网开放 5432，仅内网或 SSH 隧道。

# Docker Compose 部署时：数据库在 compose 里的 postgres 容器，连接串由 docker-compose.yml 注入，
# 一般不需要在服务器上改 backend/.env 的 DATABASE_URL（除非你改成「自建主机 Postgres」架构）。

REDIS_URL=redis://localhost:6379/0

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

LLM_BASE_URL=https://your-proxy.com/v1
LLM_DEFAULT_MODEL=claude-3-5-sonnet-20241022
LLM_FALLBACK_MODEL=claude-3-5-haiku-20241022
# 对话单次回复输出上限（token）；官方/不同中转上限不同，报 400 时可改小
LLM_CHAT_MAX_OUTPUT_TOKENS=16384
# 同一助手气泡最多几段流式拼接（每段受中转 ~4k token 限制时会自动续写）
LLM_CHAT_MAX_SEGMENTS=8

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

CELERY_WORKER_CONCURRENCY=15

# ── 建表（Alembic）──────────────────────────────────────────────────────────
# 本地：在 backend 目录执行，且已配置好上面的 DATABASE_URL
#   Windows PowerShell:  $env:DATABASE_URL="postgresql+asyncpg://..." ; alembic upgrade head
#   Linux/macOS:        DATABASE_URL="postgresql+asyncpg://..." alembic upgrade head
# Docker 部署：首次 `docker compose up -d` 时会自动跑 migrate 容器执行 `alembic upgrade head`，无需在服务器手工建表。
